<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crypto Dashboard</title>
    <link rel="icon" type="image/png" href="/image/cs-logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
    <%    //check if the value is defined (string, number) 
        //if not, return unavailable
        const formatUsd = (value, includeDecimals = false) => { 
            if (value === null || value === undefined) return "Unavailable";

            const absoluteValue = Math.abs(value);
            const maximumFractionDigits = includeDecimals
                ? (absoluteValue > 0 && absoluteValue < 1 ? 8 : 2)
                : 0;
                //handle token price properly, 
                // added this because memecoins have decimals up to 8 places
            return new Intl.NumberFormat("en-US", {
                style: "currency",
                currency: "USD",
                minimumFractionDigits: 0,
                maximumFractionDigits
            }).format(value);
        };


        //add positive or negative signs to changes
        const formatPercentage = (value) => {
            if (value === null || value === undefined) return "Unavailable";
            return `${value > 0 ? "+" : ""}${value.toFixed(2)}%`;
        };

        //check if js created a real date, if not return unavailable
        const formatDate = (value) => {
            if (!value) return "Unavailable";

            const date = new Date(value);
            return Number.isNaN(date.getTime()) ? "Unavailable" : date.toLocaleString();
        };
    %>

    <header class="site-header">
        <a href="/" class="brand">
            <span class="brand-logo" aria-hidden="true"></span>
            <span>CoinScope</span>
        </a>

        <span class="live-status">
            <span></span>
            Live market data
        </span>
    </header>

    
    <main>
        <section class="intro">
            <p class="eyebrow">Live cryptocurrency prices</p>
            <h1 class="page-title">Crypto Market Dashboard</h1>
            <p>View current prices, market capitalization, and 24-hour changes.</p>
        </section>

        <section class="dashboard">
            <form action="/" method="GET" class="coin-picker">
                
                <label for="coin">Choose preferred token:</label>
                <div class="select-row">
                
                    <input
                        type="text"
                        name="coin"
                        id="coin"
                        list="coin-list"
                        value="<%= selectedCoin %>"
                        required
                    >

                    <datalist id="coin-list">
                        <%# loop through all the tokens and find the one with the specific 
                        id being searched %>
                        <% coins.forEach(coin => { %>
                            <option value="<%= coin.id %>">
                                <%= coin.name %> (<%= String(coin.symbol || "").toUpperCase() %>)
                            </option>
                        <% }); %>
                    </datalist>


                    <button type="submit">View Coin</button>
                </div>
            </form>

            <% if (error) { %>
                <div class="error-state">
                    <strong>Token unavailable</strong>
                    <p><%= error %></p>
                </div>
            <% } else { %>
                <div class="asset-summary">

                    <div class="asset-identity">
                        <!-- if image is not found, show my app logo -->
                        <img src="<%= data.image || "/image/cs-logo.png" %>" class="coin-image" alt="<%= data.name || selectedCoin %> logo">

                        <div>
                            <h2><%= data.name || selectedCoin %> <%= String(data.symbol || "").toUpperCase() %></h2>

                            <strong class="<%= data.price_change_percentage_24h > 0
                                ? "positive-text"
                                : data.price_change_percentage_24h < 0
                                    ? "negative-text"
                                    : "" %>">
                                <%= formatPercentage(data.price_change_percentage_24h) %>
                            </strong>
                        </div>
                    </div>
                </div>

                <div class="metrics">
                    <article class="metric primary-metric">
                        <p>Current Price:</p> 
                        <strong><%= formatUsd(data.current_price, true) %></strong>
                    </article>

                    <article class="metric">
                            <p>Market cap: </p>
                            <strong><%= formatUsd(data.market_cap) %></strong>
                    </article>

                </div>

                <div class="secondary-metrics">
                    <article class="secondary-metric">
                        <p>FDV:</p>
                        <strong><%= formatUsd(data.fully_diluted_valuation) %></strong>
                    </article>

                    <article class="secondary-metric">
                        <p>Total Volume:</p>
                        <strong><%= formatUsd(data.total_volume) %></strong>
                    </article>

                    <article class="secondary-metric">
                        <p>ATH:</p>
                        <strong><%= formatUsd(data.ath, true) %></strong>
                    </article>

                    <article class="secondary-metric">
                        <p>ATL:</p>
                        <strong><%= formatUsd(data.atl, true) %></strong>
                    </article>

                </div>

                <p class="updated-at">
                        Last updated:
                        <%= formatDate(data.last_updated) %>
                </p>  
            <% } %>
        </section>
    </main>
    
    <footer>
        Market data provided by CoinGecko. Prices may be delayed.
    </footer>
</body>
</html>